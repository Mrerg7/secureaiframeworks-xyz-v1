---
import { ACQUISITION_MAILTO, SITE } from '../config/site';
---

<section id="inquire" class="bg-white/5 border-t border-white/10 py-16">
  <div class="max-w-2xl mx-auto px-6">
    <div class="text-center mb-10">
      <h2 class="text-4xl font-semibold tracking-tight">Ready to own the modern domain for secure AI?</h2>
      <p class="mt-3 text-white/70">Submit your inquiry. We respond personally to serious buyers within 24 hours.</p>
    </div>

    <!-- Form -->
    <form id="inquiry-form" class="glass rounded-3xl p-8 md:p-10 space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <label class="block text-xs tracking-widest font-medium text-white/60 mb-1.5">FULL NAME</label>
          <input type="text" id="name" required
                 class="form-input w-full bg-white/5 border border-white/15 rounded-2xl px-5 py-3.5 text-white placeholder:text-white/40 focus:border-[#22f5ff]/60" />
        </div>
        <div>
          <label class="block text-xs tracking-widest font-medium text-white/60 mb-1.5">EMAIL ADDRESS</label>
          <input type="email" id="email" required
                 class="form-input w-full bg-white/5 border border-white/15 rounded-2xl px-5 py-3.5 text-white placeholder:text-white/40 focus:border-[#22f5ff]/60" />
        </div>
      </div>

      <div>
        <label class="block text-xs tracking-widest font-medium text-white/60 mb-1.5">ORGANIZATION OR INTENDED USE (OPTIONAL)</label>
        <input type="text" id="org"
               class="form-input w-full bg-white/5 border border-white/15 rounded-2xl px-5 py-3.5 text-white placeholder:text-white/40 focus:border-[#22f5ff]/60" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <label class="block text-xs tracking-widest font-medium text-white/60 mb-1.5">YOUR OFFER (OPTIONAL)</label>
          <div class="relative">
            <span class="absolute left-5 top-1/2 -translate-y-1/2 text-white/40">$</span>
            <input type="text" id="offer" placeholder="9997"
                   class="form-input w-full bg-white/5 border border-white/15 rounded-2xl pl-8 pr-5 py-3.5 text-white placeholder:text-white/40 focus:border-[#22f5ff]/60" />
          </div>
        </div>
        <div>
          <label class="block text-xs tracking-widest font-medium text-white/60 mb-1.5">TIMELINE</label>
          <select id="timeline" class="form-input w-full bg-[#0a0a0f] bg-white/5 border border-white/15 rounded-2xl px-5 py-[15px] text-white focus:border-[#22f5ff]/60">
            <option value="" class="bg-[#0a0a0f]">Select preferred timeline</option>
            <option value="immediate" class="bg-[#0a0a0f]">Immediate (within 7 days)</option>
            <option value="2weeks" class="bg-[#0a0a0f]">Within 2 weeks</option>
            <option value="month" class="bg-[#0a0a0f]">Within 30 days</option>
            <option value="flexible" class="bg-[#0a0a0f]">Flexible / exploring</option>
          </select>
        </div>
      </div>

      <div>
        <label class="block text-xs tracking-widest font-medium text-white/60 mb-1.5">MESSAGE OR QUESTIONS</label>
        <textarea id="message" rows="4" placeholder="What is your vision for secureaiframeworks.xyz?"
                  class="form-input w-full bg-white/5 border border-white/15 rounded-3xl px-5 py-4 text-white placeholder:text-white/40 focus:border-[#22f5ff]/60 resize-y min-h-[110px]"></textarea>
      </div>

      <button type="submit"
              class="w-full py-4 rounded-3xl bg-gradient-to-r from-[#22f5ff] to-[#a855f7] font-semibold text-[#0a0a0f] text-lg tracking-[-0.2px] active:scale-[0.985] transition-all hover:brightness-105">
        Submit Secure Inquiry
      </button>

      <p class="text-center text-[10px] text-white/50 tracking-wide">Your information is kept confidential. All transactions protected via escrow.</p>
    </form>

    <!-- Success Message (hidden by default) -->
    <div id="success-message" class="hidden mt-6 glass rounded-3xl p-8 border border-emerald-400/30 text-center">
      <div class="mx-auto w-14 h-14 rounded-full bg-emerald-400/10 flex items-center justify-center mb-5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 10l7-7m0 0l7 7" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21V3" />
        </svg>
      </div>
      <h3 class="text-2xl font-semibold tracking-tight mb-2">Inquiry Received</h3>
      <p class="text-white/70 max-w-xs mx-auto">Thank you. A member of our team will personally respond within 24 hours to discuss next steps.</p>
      <button id="reset-form-btn"
              class="mt-6 text-sm font-medium text-white/60 hover:text-white underline underline-offset-4">Submit another inquiry</button>
    </div>
  </div>
</section>
