---
import { SITE } from '../config/site';
---

<nav id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <div class="flex items-center gap-x-3">
        <div class="w-9 h-9 rounded-2xl bg-gradient-to-br from-[#22f5ff] via-[#a855f7] to-[#22f5ff] p-px">
          <div class="w-full h-full bg-[#0a0a0f] rounded-2xl flex items-center justify-center">
            <span class="text-[#22f5ff] text-lg font-bold tracking-tighter">SAF</span>
          </div>
        </div>
        <div class="font-display text-2xl font-semibold tracking-tighter">
          {SITE.name}
        </div>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-x-9 text-sm font-medium">
        <a href="#positioning" class="text-white/80 hover:text-white transition-colors">The Opportunity</a>
        <a href="#why" class="text-white/80 hover:text-white transition-colors">Why This Domain</a>
        <a href="#uses" class="text-white/80 hover:text-white transition-colors">Ideal For</a>
        <a href="#pricing" class="text-white/80 hover:text-white transition-colors">Pricing</a>
      </div>

      <!-- CTA Buttons -->
      <div class="flex items-center gap-x-3">
        <a href="#inquire"
           class="hidden sm:inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold rounded-2xl border border-white/20 hover:bg-white/5 transition-colors">
          Inquire
        </a>
        <a href="#inquire"
           class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold rounded-2xl bg-white text-[#0a0a0f] hover:bg-white/90 transition-all active:scale-[0.985]">
          Secure Now
        </a>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn"
                class="md:hidden w-10 h-10 flex items-center justify-center text-white/70 hover:text-white transition-colors"
                aria-label="Toggle menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden fixed inset-0 z-40 bg-[#0a0a0f] pt-20">
    <div class="px-6 py-8 flex flex-col gap-y-6 text-lg font-medium">
      <a href="#positioning" class="mobile-nav-link py-2">The Opportunity</a>
      <a href="#why" class="mobile-nav-link py-2">Why This Domain</a>
      <a href="#uses" class="mobile-nav-link py-2">Ideal For</a>
      <a href="#pricing" class="mobile-nav-link py-2">Pricing</a>
      <div class="pt-4 border-t border-white/10">
        <a href="#inquire" class="block w-full text-center py-3.5 rounded-2xl bg-white text-[#0a0a0f] font-semibold">Secure This Domain</a>
      </div>
    </div>
  </div>
</nav>
